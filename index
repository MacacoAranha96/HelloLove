<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Carta de Amor</title>
  <link href="https://fonts.googleapis.com/css?family=Sofia" rel="stylesheet">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
  <style>

  * {
    -webkit-tap-highlight-color: transparent;
    padding: 0;
    margin: 0;
    box-sizing: border-box;
  }

  html, body { height: 100%; }

  body {
    width: 100%;
   background-position:center ;
    background-image:url("35 Sem Título_20260405023917.png;")
    background-size: 100%;
    background-position: top;
    background-repeat: no-repeat;
    background-attachment: fixed;
    font-size: 20px;
    display: flex;
    justify-content: center;
    align-items: center;
    overflow: hidden;
  }

  @media (max-height: 500px) {
    body { margin: 25% 0 25% 0; }
  }

  #particle-canvas {
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    pointer-events: none;
    z-index: 0;
  }

  /* ── ENVELOPE ── */
  .envelop {
    width: 15rem;
    height: 10rem;
    position: absolute;
    left: 0; right: 0;
    margin: auto;
    z-index: 10;
  }

  @media (min-width: 400px) and (max-width: 600px) {
    .envelop { width: 20rem; height: 15rem; }
  }
  @media (min-width: 600px) {
    .envelop { width: 25rem; height: 20rem; }
  }
  @media (min-width: 600px) and (min-height: 600px) {
    .envelop { bottom: 20%; }
  }

  .envelop__front-paper {
    width: 100%; height: 100%;
    bottom: 0; left: 0;
    position: absolute;
    border-radius: 0.7rem;
    border: 0.35rem solid #967b5c;
    background-color: #ba9872;
    clip-path: polygon(100% 0%, 50% 70%, 0% 0%, 0% 100%, 100% 100%);
    z-index: 300;
  }

  .envelop__back-paper {
    height: 100%;
    bottom: 0; left: 0;
    position: absolute;
    border-radius: 0.7rem;
    background-color: #967b5c;
    clip-path: polygon(0% 0%, 100% 0%, 90% 100%, 0% 90%);
    z-index: 100;
  }

  .envelop__up-paper {
    width: 100%; height: 100%;
    bottom: 0; left: 0;
    position: relative;
    border-radius: 0.7rem;
    background-color: #967b5c;
    z-index: 400;
    clip-path: polygon(0% 0%, 100% 0%, 50% 81%);
  }

  /* ── FITA: textura de corações (original) + borda de lacre ── */
  .envelop__sticker {
    width: 101%;
    height: 20%;
    position: absolute;
    margin: auto;
    top: 30%;
    left: 0; bottom: 0; right: 0;
    z-index: 500;

    /* Fundo branco + imagem de coração repetida (padrão original) */
    background-color: #f9f9f9;
    background-image: url("https://www.freepnglogos.com/uploads/heart-png/emoji-heart-33.png");
    background-size: 20rem;
    background-position: center;
    background-repeat: repeat;

    border: 0.3rem solid #e2e2e2;

    /* Overlay de textura de cetim por cima dos corações */
    box-shadow:
      0 3px 10px rgba(0,0,0,0.35),
      inset 0 1px 3px rgba(255,255,255,0.5),
      inset 0 -1px 3px rgba(0,0,0,0.15);

    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    overflow: visible;
    transition: filter 0.2s, transform 0.15s;
    transform-origin: center;
  }

  .envelop__sticker:hover {
    filter: brightness(1.08);
    transform: scaleY(1.05);
  }

  @media (max-width: 400px) {
    .envelop__sticker { background-size: 2rem; }
  }
  @media (min-width: 600px) {
    .envelop__sticker { height: 15%; }
  }

  /* ── CORAÇÃO NA FITA ── */
  .ribbon-heart {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    height: 350%;
    width: auto;
    pointer-events: none;
    z-index: 510;
    filter: drop-shadow(0 2px 8px rgba(0,0,0,0.35));
    transition: opacity 0.25s ease, transform 0.25s ease;
  }

  .ribbon-heart.hidden {
    opacity: 0;
    transform: translate(-50%, -60%) scale(0.4);
  }

  /* ── false-sticker REMOVIDO ── */

  .envelop__content {
    width: 100%; height: 100%;
    bottom: 0; left: 0;
    position: absolute;
    z-index: 200;
  }

  .love-notes {
    width: 100%; height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .note {
    width: 95%;
    height: 30%;
    background-color: #f9f9f9;
    position: absolute;
    overflow: hidden;
    transition: height 0.5s, opacity 0.25s;
    box-shadow: 0px 0px 5px 0px rgba(0,0,0,0.75);
  }

  .note:nth-child(1) { bottom: 60%; }
  .note:nth-child(2) { bottom: 40%; }
  .note:nth-child(3) { bottom: 20%; }

  .note:hover {
    cursor: pointer;
    height: 45%;
  }

  .note__text {
    font-family: "Sofia";
    padding: 0.3rem;
  }

  .note__text p {
    font-size: 0.1rem;
    margin-bottom: 1rem;
    text-align: center;
  }

  @media (min-width: 300px) and (max-width: 600px) {
    .note__text p { font-size: 0.7rem; }
  }
  @media (min-width: 600px) {
    .note__text p { font-size: 0.8rem; }
  }

  .scissors {
    cursor: url("https://i.postimg.cc/GtLCdKxR/sisors.png"), pointer;
  }
  .scissors:active {
    cursor: url("https://i.postimg.cc/GtXQ7WPZ/pngwing-com.png"), pointer;
  }
  .cursor { cursor: pointer; }

  .sticker {
    height: 50px;
    width: auto;
  }

  /* ── ANIMAÇÃO FITA ABRINDO ── */
  @keyframes ribbonSplit {
    0%   { clip-path: inset(0 0 0 0);     opacity: 1; }
    30%  { clip-path: inset(0 0 0 0);     opacity: 1; }
    65%  { clip-path: inset(45% 0 45% 0); opacity: 0.6; }
    100% { clip-path: inset(50% 0 50% 0); opacity: 0; }
  }

  .ribbon-opening {
    animation: ribbonSplit 0.5s ease-in forwards;
    pointer-events: none;
  }
  </style>
</head>
<body class="scissors">

  <canvas id="particle-canvas"></canvas>

  <div class="envelop">
    <div class="envelop__front-paper"></div>
    <div class="envelop__back-paper"></div>
    <div class="envelop__up-paper js-up-paper"></div>

    <!-- ══ FITA ══ -->
    <div class="envelop__sticker js-sticker">
      <!--
        IMAGEM DO LACRE
        Arquivo: "29 Sem Título_20260308105915.png"
        Coloque na mesma pasta do HTML.
      -->
      <img
        class="ribbon-heart js-ribbon-heart"
        src="29 Sem Título_20260308105915.png"
        alt="coração"
      >
    </div>

    <!-- false-sticker removido -->

    <div class="envelop__content js-envelop-content">
      <div class="love-notes">

        <!-- NOTA 1 -->
        <div class="note js-note">
          <div class="note__text">
            <p>
              Opaa minha cheirosa, eu só queria te lembrar o quanto eu te amo.
              Cada neurônio no meu cérebrozinho pensa em você. Nem o céu cheio de estrelas,
              nem o mar inteiro, chegariam perto
              do que eu sinto por você. Se cada segundo do meu dia pudesse virar uma frase,
              todas elas seriam dizendo o quanto você é importante pra mim.
             Eu te amo, <span style="color:#ff4af0;">meu amor.</span>
              <br>
              <img class="sticker" src="hello_kitty_PNG22.png">
            </p>
          </div>
        </div>

        <!-- NOTA 2 -->
        <div class="note js-note">
          <div class="note__text">
            <p>
              Tudo que eu quero é passar o resto da minha vida ao seu lado,
              seja nos momentos bons ou ruins. Somente <span style="color:#235ddb;">Rian</span>
              e <span style="color:#ff4af0;">Helloisa</span> contra o mundo.
              Quero no futuro, daqui a algumas décadas, segurar sua mão e falar
              "lembra quando a gente se conhecia só pela internet?"
              Aí você vai rir e falar "você era um lixo de homem",
              e eu vou responder "pelo menos eu era um homem" —
              aí você vai me bater e a gente vai acabar feliz
              assistindo anime e comendo recheado com seus ratos 🐹
              <br>
              <img class="sticker" src="file_0000000009e871fbb9ef3ff37d2072c1.png">
            </p>
          </div>
        </div>

        <!-- NOTA 3 -->
        <div class="note js-note">
          <div class="note__text">
            <p>
              Helloisa, meu amor — não importa o que de ruim aconteça no meu dia,
              eu chego feliz em casa sabendo que vou poder conversar com você.
              Todos os dias eu imagino como seria horrível te perder,
              mas também imagino o quanto vai ser incrível viver o resto da minha vida
              ao seu lado. Espero que meu nome esteja ao lado do seu no destino
              que Deus nos escolheu. Esse é meu jeito de demonstrar todo o amor
              que poderia ter te dado antes. Quero ser o melhor homem possível para você
              e não te fazer se arrepender de casar comigo.
           
              Você é a melhor coisa que me aconteceu.
              Obrigado por me escolher todos os dias.
              <br>
              Te amo muito, <span style="color:#ff4af0;">Helloisa</span>! ♥
              <br>
              <img class="sticker" src="38 Sem Título_20260510233920.png" style="border-radius:3px">
            </p>
            <br>
          </div>
        </div>

      </div>
    </div>
  </div>

  <script>
    /* ══════════════════════════════════════════
       PARTICLE SYSTEM
    ══════════════════════════════════════════ */
    const canvas = document.getElementById('particle-canvas');
    const ctx = canvas.getContext('2d');

    function resize() {
      canvas.width  = window.innerWidth;
      canvas.height = window.innerHeight;
    }
    resize();
    window.addEventListener('resize', resize);

    const SYMBOLS = ['❤️','💕','💖','🐹','💓','🩷','✨','🌸','🤎','🪻','💞','🫶'];

    class Particle {
      constructor() { this.reset(true); }

      reset(initial = false) {
        this.x            = Math.random() * canvas.width;
        this.y            = initial
          ? canvas.height + Math.random() * canvas.height
          : canvas.height + 20 + Math.random() * 60;
        this.size         = 10 + Math.random() * 18;
        this.speedY       = 0.4 + Math.random() * 0.9;
        this.drift        = (Math.random() - 0.5) * 0.6;
        this.wobbleFreq   = 0.01 + Math.random() * 0.03;
        this.wobbleOffset = Math.random() * Math.PI * 2;
        this.alpha        = 1;
        this.symbol       = SYMBOLS[Math.floor(Math.random() * SYMBOLS.length)];
        this.rotation     = (Math.random() - 0.5) * 0.4;
        this.rotSpeed     = (Math.random() - 0.5) * 0.02;
        this.tick         = 0;
      }

      update() {
        this.tick++;
        this.y -= this.speedY;
        this.x += Math.sin(this.tick * this.wobbleFreq + this.wobbleOffset) * 0.5 + this.drift * 0.1;
        this.rotation += this.rotSpeed;

        const fadeStart = canvas.height * 0.6;
        const fadeEnd   = canvas.height * 0.1;
        this.alpha = this.y < fadeStart
          ? Math.max(0, (this.y - fadeEnd) / (fadeStart - fadeEnd))
          : 1;

        if (this.alpha <= 0 || this.y < -this.size) this.reset();
      }

      draw() {
        ctx.save();
        ctx.globalAlpha = this.alpha;
        ctx.font = `${this.size}px serif`;
        ctx.textAlign    = 'center';
        ctx.textBaseline = 'middle';
        ctx.translate(this.x, this.y);
        ctx.rotate(this.rotation);
        ctx.fillText(this.symbol, 0, 0);
        ctx.restore();
      }
    }

    const PARTICLE_COUNT = Math.min(60, Math.floor((window.innerWidth * window.innerHeight) / 12000));
    const particles = Array.from({ length: PARTICLE_COUNT }, () => new Particle());

    function loop() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      for (const p of particles) { p.update(); p.draw(); }
      requestAnimationFrame(loop);
    }
    loop();

    /* ══════════════════════════════════════════
       ENVELOPE LOGIC
    ══════════════════════════════════════════ */
    let mobile_media_query = window.matchMedia("(max-width: 400px)");
    let tablet_media_query = window.matchMedia("(min-width: 400px) and (max-width: 600px)");
    const notes = document.querySelectorAll(".js-note");

    function recize_notes() {
      notes.forEach(n => {
        if (n.classList.contains("active")) {
          n.classList.remove("active");
          gsap.set(n, { height: "30%", clearProps: "all" });
        }
      });
    }

    function notes_ready() {
      gsap.to(".js-envelop-content", { height: "110%", duration: 0.5 });
      notes.forEach((note, i) => {
        note.addEventListener("click", function () {
          const isActive = this.classList.contains("active");
          notes.forEach(n => {
            n.classList.remove("active");
            gsap.set(n, { height: "30%", clearProps: "all" });
          });
          if (!isActive) {
            this.classList.add("active");
            if (mobile_media_query.matches) {
              gsap.set(this, { height: 125 + 40 * i + "%" });
            } else if (tablet_media_query.matches) {
              gsap.set(this, { height: 80 + 21 * i + "%" });
            } else {
              gsap.set(this, { height: 70 + 20 * i + "%" });
            }
          }
        });
      });
    }

    function set_up_paper() {
      gsap.set(".js-up-paper", {
        bottom: "97%",
        rotation: 180,
        zIndex: 200,
        clipPath: "polygon(0% 0%, 100% 0%, 50% 61%)",
        onComplete: notes_ready
      });
    }

    function envelop_transition() {
      gsap.to(".js-up-paper", { bottom: "1%", duration: 0.25, onComplete: set_up_paper });
      document.querySelector(".js-up-paper").removeEventListener("click", envelop_transition);
      document.querySelector(".js-up-paper").classList.remove("cursor");
    }

    /* ── FITA: coração some → fita rasga → aba ativa ── */
    function sticker() {
      const ribbonEl = document.querySelector(".js-sticker");
      const heartImg = document.querySelector(".js-ribbon-heart");

      // 1. Coração some
      heartImg.classList.add("hidden");

      // 2. Pausa curta, depois a fita "rasga"
      setTimeout(() => {
        ribbonEl.classList.add("ribbon-opening");

        ribbonEl.addEventListener("animationend", () => {
          ribbonEl.style.display = "none";
          document.body.classList.remove("scissors");

          // 3. Ativa clique na aba
          document.querySelector(".js-up-paper").addEventListener("click", envelop_transition);
          document.querySelector(".js-up-paper").classList.add("cursor");
        }, { once: true });
      }, 200);

      ribbonEl.removeEventListener("click", sticker);
    }

    document.querySelector(".js-sticker").addEventListener("click", sticker);

    window.onresize = () => recize_notes();
  </script>
</body>
</html>
